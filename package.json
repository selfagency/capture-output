{
  "name": "capture-output",
  "version": "2.0.0",
  "description": "Capture the output (and duration) of a command as a GitHub Actions `output` or file",
  "license": "MIT",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/capture-output.git"
  },
  "type": "module",
  "main": "dist/action.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit --project .",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "format": "oxfmt --write",
    "lint": "oxlint",
    "lint-staged": "lint-staged --allow-empty",
    "lint:fix": "oxlint --fix",
    "prepare": "husky install",
    "start": "npx tsx src/action.ts"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/exec": "3.0.0",
    "@actions/io": "3.0.2"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsup": "^8.5.1",
    "@vitest/coverage-v8": "^4.1.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.{js,json,md,yml}": [
      "pnpm lint:fix",
      "pnpm format"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}